APP_ENV="development"
APP_NAME="Multi-Agent Security Research Hub"
HOST="0.0.0.0"
PORT=8000
ARXIV_BASE_URL="https://export.arxiv.org/api/query"
DEFAULT_MAX_RESULTS=12
MAX_RESULTS_LIMIT=20
DATABASE_BACKEND="postgres"
DATABASE_URL="postgresql://researchhub_admin:researchhub_dev@localhost:5432/researchhub"
DATABASE_PATH="data/research_hub.db"

# Optional OpenAI summarization
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_SUMMARY_MODEL="gpt-4.1-mini"

# Optional scholarly source credentials
OPENALEX_API_KEY=""
OPENALEX_EMAIL=""
CROSSREF_EMAIL=""
SEMANTIC_SCHOLAR_API_KEY=""

# PDF extraction limits reused from api/
PAPER_TEXT_CHUNK_CHARS=12000
PAPER_TEXT_MAX_CHARS=120000
