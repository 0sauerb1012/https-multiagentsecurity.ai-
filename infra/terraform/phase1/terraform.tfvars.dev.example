aws_region   = "us-east-1"
project_name = "multiagentsecurity-ai"
environment  = "dev"

web_image_tag    = "latest"
lambda_image_tag = "latest"

web_cpu            = 512
web_memory         = 1024
web_desired_count  = 1
web_container_port = 8000
health_check_path  = "/"

vpc_cidr             = "10.0.0.0/16"
public_subnet_a_cidr = "10.0.1.0/24"
public_subnet_b_cidr = "10.0.2.0/24"
private_subnet_a_cidr = "10.0.11.0/24"
private_subnet_b_cidr = "10.0.12.0/24"

# Optional AWS-managed PostgreSQL for same-region app/database traffic.
managed_postgres_enabled                 = false
managed_postgres_db_name                 = "researchhub"
managed_postgres_username                = "researchhub_admin"
managed_postgres_instance_class          = "db.t4g.micro"
managed_postgres_allocated_storage       = 20
managed_postgres_engine_version          = "16.3"
managed_postgres_backup_retention_period = 7
managed_postgres_deletion_protection     = true
managed_postgres_skip_final_snapshot     = false
managed_postgres_publicly_accessible     = false

# Leave false unless you intentionally move ingestion Lambda into the VPC.
lambda_vpc_enabled = false

# Preferred: SSM SecureString parameters
database_url_param_name             = "/multiagentsecurity/dev/DATABASE_URL"
openai_api_key_param_name           = "/multiagentsecurity/dev/OPENAI_API_KEY"
openalex_api_key_param_name         = ""
openalex_email_param_name           = ""
crossref_email_param_name           = ""
semantic_scholar_api_key_param_name = ""

# Non-secret runtime config
plain_env_vars = {
  OPENAI_MODEL = "gpt-4.1-mini"
}

# Keep the defaults conservative for the first deployment.
ingestion_lambda_memory = 2048
years_back              = 5

incremental_target_limit    = 250
incremental_per_topic_limit = 40
incremental_overlap_days    = 3

reconcile_target_limit    = 500
reconcile_per_topic_limit = 60
reconcile_lookback_days   = 30

incremental_schedule_expression = "cron(0 11 * * ? *)"
reconcile_schedule_expression   = "cron(0 12 ? * SUN *)"
