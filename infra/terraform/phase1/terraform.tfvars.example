aws_region   = "us-east-1"
project_name = "multiagentsecurity-ai"
environment  = "dev"

web_image_tag    = "latest"
lambda_image_tag = "latest"

web_cpu            = 512
web_memory         = 1024
web_desired_count  = 1
web_container_port = 8000
health_check_path  = "/"

vpc_cidr             = "10.0.0.0/16"
public_subnet_a_cidr = "10.0.1.0/24"
public_subnet_b_cidr = "10.0.2.0/24"

# Prefer SSM parameter names so secrets do not live in Terraform state.
database_url_param_name               = "/multiagentsecurity/dev/DATABASE_URL"
openai_api_key_param_name             = "/multiagentsecurity/dev/OPENAI_API_KEY"
openalex_api_key_param_name           = ""
openalex_email_param_name             = ""
crossref_email_param_name             = ""
semantic_scholar_api_key_param_name   = ""

# Optional non-secret env vars.
plain_env_vars = {
  OPENAI_MODEL = "gpt-4.1-mini"
}

# Optional custom domain cutover to Route 53 and ALB HTTPS.
enable_custom_domain   = false
domain_name            = "multiagentsecurity.ai"
create_public_hosted_zone = false
hosted_zone_id         = ""
create_www_record      = true

# Preserve existing non-web HostGator records here when migrating DNS.
# Leave the apex and www website records out of this list; Terraform manages
# those separately as ALB alias records when custom domain support is enabled.
dns_records = [
  { name = "autoconfig", type = "A", ttl = 3600, records = ["50.6.252.207"] },
  { name = "autodiscover", type = "A", ttl = 3600, records = ["50.6.252.207"] },
  { name = "cpanel", type = "A", ttl = 14400, records = ["50.6.252.207"] },
  { name = "ftp", type = "A", ttl = 14400, records = ["50.6.252.207"] },
  { name = "mail", type = "A", ttl = 3600, records = ["50.6.252.207"] },
  { name = "ssh", type = "A", ttl = 7200, records = ["50.6.252.207"] },
  { name = "webdisk", type = "A", ttl = 3600, records = ["50.6.252.207"] },
  { name = "webmail", type = "A", ttl = 14400, records = ["50.6.252.207"] },
  { name = "whm", type = "A", ttl = 3600, records = ["50.6.252.207"] },
  { name = "imap", type = "CNAME", ttl = 3600, records = ["mail.multiagentsecurity.ai"] },
  { name = "pop", type = "CNAME", ttl = 3600, records = ["mail.multiagentsecurity.ai"] },
  { name = "smtp", type = "CNAME", ttl = 3600, records = ["mail.multiagentsecurity.ai"] },
  { name = "", type = "MX", ttl = 3600, records = ["10 mail.multiagentsecurity.ai"] },
  { name = "_autodiscover._tcp", type = "SRV", ttl = 3600, records = ["0 0 443 cpanelemaildiscovery.cpanel.net"] },
  { name = "default._domainkey", type = "TXT", ttl = 3600, records = ["v=DKIM1; k=rsa; ;"] },
  { name = "", type = "TXT", ttl = 3600, records = ["v=spf1 a mx include:websitewelcome.com ~all"] },
  { name = "_dmarc", type = "TXT", ttl = 3600, records = ["v=DMARC1; p=none"] },
]

incremental_schedule_expression = "cron(0 11 * * ? *)"
reconcile_schedule_expression   = "cron(0 12 ? * SUN *)"
